COMPOSE_PROJECT_NAME=taxi_app

POSTGRES_USER=taxi
POSTGRES_PASSWORD=taxi_password
POSTGRES_DB=taxi
POSTGRES_PORT=5432

REDIS_PORT=6379

BACKEND_PORT=3000
ADMIN_PORT=3001
CUSTOMER_PORT=8081
DRIVER_PORT=8082

DATABASE_URL=postgresql://taxi:taxi_password@postgres:5432/taxi?schema=public
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
DEV_LOGIN_ENABLED=false
CORS_ORIGINS=http://localhost:3001,http://localhost:8081,http://localhost:8082
MAPBOX_ACCESS_TOKEN=replace-with-mapbox-token
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000/taxi
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000/taxi
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=replace-with-mapbox-token
