{
  "expo": {
    "name": "Taxi Customer",
    "slug": "taxi-customer",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "taxicustomer",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": "replace-with-mapbox-download-token"
        }
      ]
    ],
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f766e"
      }
    }
  }
}
