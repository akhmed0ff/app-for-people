COMPOSE_PROJECT_NAME=taxi_app

POSTGRES_USER=taxi
POSTGRES_PASSWORD=taxi_password
POSTGRES_DB=taxi
POSTGRES_PORT=5432

REDIS_PORT=6379

BACKEND_PORT=3000
ADMIN_PORT=3001

DATABASE_URL=postgresql://taxi:taxi_password@localhost:5432/taxi?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-local-access-secret
JWT_REFRESH_SECRET=replace-with-local-refresh-secret

NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000/taxi

EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000/taxi
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=replace-with-mapbox-token
